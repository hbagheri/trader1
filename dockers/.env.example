# Docker stack secrets (copy to .env, never commit .env)
# ─── MariaDB ───
MYSQL_ROOT_PASSWORD=replace-me

# ─── physicalme.ir WP ───
PHYSICALME_DB_NAME=physicalme
PHYSICALME_DB_USER=physics_user
PHYSICALME_DB_PASSWORD=replace-me

# ─── ayimi WP ───
AYIMI_DB_NAME=ayimi
AYIMI_DB_USER=ayimi_user
AYIMI_DB_PASSWORD=replace-me

# ─── Cloudflare Tunnel (issued by dash.cloudflare.com → Zero Trust → Networks → Tunnels) ───
TUNNEL_TOKEN=replace-me
